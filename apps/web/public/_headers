# Long-cache hashed build assets (Vite content-hashed filenames).
# Only safe when missing files return real 404 — disable Cloudflare SPA fallback.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Prerendered HTML shells — revalidate after every deploy so users never keep an
# index that references a deleted post-deploy asset hash.
/
  Cache-Control: public, max-age=0, must-revalidate

/guide
  Cache-Control: public, max-age=0, must-revalidate

/en
  Cache-Control: public, max-age=0, must-revalidate

/en/guide
  Cache-Control: public, max-age=0, must-revalidate

# Standalone 404 page (used when SPA fallback is disabled).
/404.html
  Cache-Control: no-store

# Manifest and icons — moderate cache
/site.webmanifest
  Cache-Control: public, max-age=86400
