{
  "name": "html-deck-studio",
  "private": true,
  "version": "0.1.0",
  "description": "HTML Deck Studio monorepo – trim AI-generated HTML decks, export pixel-perfect PPTX/PDF",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter './apps/*' dev",
    "build": "pnpm --filter '@hds/protocol' build && pnpm --parallel --filter './apps/*' build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "typescript": "^5.5.4"
  }
}
